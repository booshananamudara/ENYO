{
  "manifest_version": 3,
  "name": "EnyoCart — Shop Anywhere, Checkout Once",
  "short_name": "EnyoCart",
  "version": "1.0.1",
  "description": "Add products from any online store to one secure cart. Pay with crypto, cards, local methods & more.",
  "author": "ENYO",

  "permissions": [
    "storage",
    "activeTab",
    "sidePanel"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "content/scrapers/generic.js",
        "content/scrapers/amazon.js",
        "content/scrapers/ebay.js",
        "content/scrapers/walmart.js",
        "content/scrapers/nike.js",
        "content/scrapers/etsy.js",
        "content/content.js"
      ],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "EnyoCart",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    }
  },

  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },

  "options_page": "options/options.html",

  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["assets/*", "assets/icons/*", "assets/logo/*"],
      "matches": ["<all_urls>"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
